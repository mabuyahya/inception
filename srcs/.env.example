# MariaDB
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=wordpress
MYSQL_USER=change_me_db_user
MYSQL_PASSWORD=change_me_db_password

# WordPress DB connection
WORDPRESS_DB_HOST=mariadb:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=change_me_db_user
WORDPRESS_DB_PASSWORD=change_me_db_password

# WordPress admin (username must NOT contain "admin" or "administrator")
WORDPRESS_ADMIN_USER=change_me_username
WORDPRESS_ADMIN_PASSWORD=change_me_admin_password
WORDPRESS_ADMIN_EMAIL=change_me@example.com

# WordPress regular user
WORDPRESS_USER=change_me_user
WORDPRESS_USER_PASSWORD=change_me_user_password
WORDPRESS_USER_EMAIL=change_me_user@example.com

# Domain
DOMAIN_NAME=login.42.fr

# Host data directories for named volumes
DATA_PATH=/home/login/data
